VOLCENGINE_OMNIHUMAN_SECRET_ACCESS_KEY=
VOLCENGINE_OMNIHUMAN_MAX_WAIT_SECONDS=120
VOLCENGINE_OMNIHUMAN_POLL_INTERVAL_SECONDS=3
VOLCENGINE_OMNIHUMAN_OUTPUT_RESOLUTION=720
VOLCENGINE_OMNIHUMAN_FAST_MODE=true

HTTP_PROXY=
